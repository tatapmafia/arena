{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Debate Result",
  "description": "Structured output from a debate-protocol session",
  "type": "object",
  "required": ["meta", "agents", "rounds", "consensus", "quality_metrics"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["id", "question", "strategy"],
      "properties": {
        "id": {"type": "string", "description": "Unique debate identifier"},
        "question": {"type": "string", "description": "The question being debated"},
        "strategy": {"type": "string", "description": "Debate strategy used (e.g., adversarial)"},
        "preset": {"type": "string", "description": "Preset used, if any"},
        "started_at": {"type": "string", "format": "date-time"},
        "completed_at": {"type": "string", "format": "date-time"},
        "agent_count": {"type": "integer", "minimum": 3},
        "round_count": {"type": "integer", "minimum": 1},
        "workspace": {"type": "string", "description": "Path to debate workspace directory"},
        "judge_enabled": {"type": "boolean", "description": "Whether judge evaluation was used"}
      }
    },
    "agents": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["role", "initial_position", "final_position", "confidence_trajectory"],
        "properties": {
          "role": {"type": "string"},
          "description": {"type": "string"},
          "provider": {"type": "string", "description": "LLM provider (claude, openai, etc.)"},
          "model": {"type": "string", "description": "Model identifier (opus, sonnet, gpt-4o, etc.)"},
          "initial_position": {"type": "string"},
          "final_position": {"type": "string"},
          "confidence_trajectory": {
            "type": "array",
            "items": {"type": "number", "minimum": 0, "maximum": 10},
            "description": "Confidence at each stage: [initial, after_rounds, revised, final]"
          },
          "position_changed": {"type": "boolean"},
          "change_trigger": {"type": "string", "description": "What caused the position change"}
        }
      }
    },
    "rounds": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["number", "pitcher"],
        "properties": {
          "number": {"type": "integer"},
          "pitcher": {"type": "string"},
          "devil_advocate": {"type": "string"},
          "fatal_flaws": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["author", "flaw"],
              "properties": {
                "author": {"type": "string"},
                "flaw": {"type": "string"},
                "accepted": {"type": "boolean"},
                "response": {"type": "string"}
              }
            }
          },
          "key_arguments": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "consensus": {
      "type": "object",
      "required": ["agreed", "contested", "recommendations"],
      "properties": {
        "agreed": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Points all agents agree on"
        },
        "contested": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "point": {"type": "string"},
              "for": {"type": "object", "properties": {"agents": {"type": "array", "items": {"type": "string"}}, "argument": {"type": "string"}}},
              "against": {"type": "object", "properties": {"agents": {"type": "array", "items": {"type": "string"}}, "argument": {"type": "string"}}}
            }
          }
        },
        "recommendations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["priority", "action", "confidence"],
            "properties": {
              "priority": {"type": "string", "enum": ["P0", "P1", "P2"]},
              "action": {"type": "string"},
              "confidence": {"type": "number", "minimum": 0, "maximum": 1},
              "conditions": {"type": "array", "items": {"type": "string"}}
            }
          }
        },
        "decision_framework": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "if": {"type": "string"},
              "then": {"type": "string"}
            }
          }
        },
        "key_insight": {"type": "string", "description": "Insight that emerged ONLY from adversarial debate"}
      }
    },
    "quality_metrics": {
      "type": "object",
      "properties": {
        "positions_changed": {"type": "integer"},
        "fatal_flaws_total": {"type": "integer"},
        "fatal_flaws_accepted": {"type": "integer"},
        "groupthink_flag": {"type": "boolean"},
        "average_final_confidence": {"type": "number"}
      }
    },
    "judge_report": {
      "type": "object",
      "description": "Judge evaluation (present when judge is enabled)",
      "properties": {
        "debate_quality_score": {"type": "number", "minimum": 1, "maximum": 10},
        "agent_scores": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": {"type": "string"},
              "argument_quality": {"type": "number", "minimum": 1, "maximum": 10},
              "evidence_strength": {"type": "number", "minimum": 1, "maximum": 10},
              "intellectual_honesty": {"type": "number", "minimum": 1, "maximum": 10},
              "key_contribution": {"type": "string"}
            }
          }
        },
        "strongest_arguments": {"type": "array", "items": {"type": "string"}},
        "weakest_arguments": {"type": "array", "items": {"type": "string"}},
        "groupthink_assessment": {"type": "string"}
      }
    }
  }
}
